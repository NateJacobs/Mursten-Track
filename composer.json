{
    "name": "natejacobs/mursten-track",
    "type": "library",
    "description": "A Brickset API client for tracking your collection.",
    "keywords": [
        "natejacobs",
        "lego",
		"brickset",
		"inventory",
		"collection"
    ],
    "homepage": "https://github.com/natejacobs/mursten-track",
    "license": "MIT",
    "authors": [
        {
            "name": "Nate Jacobs",
            "email": "nate@ngtj.com",
            "homepage": "https://ngtj.com",
            "role": "Developer"
        }
    ],
	"minimum-stability": "stable",
	"prefer-stable": true,
    "require": {
        "php" : "^8.4",
		"guzzlehttp/guzzle": "^7.9",
        "nesbot/carbon": "^3.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit" : "^11.5",
        "squizlabs/php_codesniffer": "^3.11"
    },
    "autoload": {
        "psr-4": {
            "NateJacobs\\MurstenTrack\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NateJacobs\\MurstenTrack\\": "tests"
        }
    }
}
